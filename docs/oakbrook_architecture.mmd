flowchart TB

    subgraph L1["USER INTERFACE — Databricks App"]
        APP["Collections Brain<br/>Chat UI + Portfolio Sidebar<br/><i>FastAPI + HTML</i>"]
    end

    subgraph L2["AI AGENT — Multi-Agent Supervisor"]
        LLM["Claude Sonnet 4.6 via FMAPI<br/><i>Tool-calling orchestration loop</i>"]
    end

    subgraph L3["AGENT TOOLS"]
        direction TB
        subgraph ML["ML Models — MLflow Model Serving"]
            direction LR
            PTP["Propensity-to-Pay<br/><i>ptp-v3.2.1 · ~1000 features</i>"]
            BTC["Best-Time-to-Contact<br/><i>btc-v2.1.0 · behavioural</i>"]
        end
        subgraph DL["Data Lookup — Unity Catalog"]
            direction LR
            C360["Customer 360<br/><i>Feature Tables</i>"]
            PAY["Payment History<br/><i>Structured Streaming</i>"]
            OB["Open Banking<br/><i>ClearScore API</i>"]
        end
        subgraph BR["Business Rules & Comms"]
            direction LR
            SC["Collection Scorecard<br/><i>MCP Server v2.4</i>"]
            VUL["Vulnerability Engine<br/><i>FCA Consumer Duty</i>"]
            RAG["Comms Generator<br/><i>RAG · Vector Search</i>"]
        end
    end

    subgraph L4["GOVERNANCE — MLflow 3.0 + Unity Catalog"]
        direction LR
        MLF["MLflow Tracing<br/><i>Full audit trail</i>"]
        UC["Unity Catalog<br/><i>Governance · Lineage</i>"]
    end

    subgraph L5["DATA SOURCES — Lakeflow Connect"]
        direction LR
        ORA["Oracle DB<br/><i>Loan Mgmt · CDC</i>"]
        ICE["SQL Server<br/><i>IceNet · CDC</i>"]
        ZEN["Zendesk<br/><i>Contacts · Stream</i>"]
        SFTP2["SFTP<br/><i>Collections</i>"]
        CS["ClearScore<br/><i>Open Banking</i>"]
    end

    APP --> LLM
