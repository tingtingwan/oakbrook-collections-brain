flowchart TB

    subgraph L1["USER INTERFACE — Databricks App"]
        APP["Collections Workbench<br/>Step-by-step analysis · Streaming<br/><i>FastAPI + SSE + HTML</i>"]
    end

    subgraph L2["AI AGENT — FMAPI + Tool-Calling"]
        LLM["Claude Sonnet 4.6 via FMAPI<br/><i>Tool-calling orchestration</i>"]
    end

    subgraph L3["AGENT TOOLS"]
        direction TB
        subgraph ML["ML Models — MLflow Model Serving"]
            direction LR
            PTP["Propensity-to-Pay<br/><i>ptp-v3.2.1</i>"]
            BTC["Best-Time-to-Contact<br/><i>btc-v2.1.0</i>"]
        end
        subgraph DL["Data — UC Feature Tables"]
            direction LR
            C360["Customer 360<br/><i>Feature Tables</i>"]
            PAY["Payment History<br/><i>Structured Streaming</i>"]
            OB["Open Banking<br/><i>ClearScore API</i>"]
        end
        subgraph BR["Rules, Comms & Compliance"]
            direction LR
            SC["Collection Scorecard<br/><i>MCP Server v2.4</i>"]
            VUL["Vulnerability Engine<br/><i>FCA Consumer Duty</i>"]
            RAG["Comms Generator<br/><i>RAG · Vector Search</i>"]
        end
    end

    subgraph L4["APPROVAL & GOVERNANCE — Unity Catalog"]
        direction LR
        APQ["Approval Queue<br/><i>UC Delta Table<br/>Human-in-the-loop</i>"]
        MLF["MLflow 3.0 Tracing<br/><i>Agent audit trail<br/>replaces Langfuse</i>"]
        UC["Unity Catalog<br/><i>Governance · Lineage<br/>Access Control</i>"]
    end

    subgraph L5["OUTPUT CHANNELS"]
        direction LR
        WA["WhatsApp<br/><i>Business API</i>"]
        SMS2["SMS<br/><i>Gateway</i>"]
        EMAIL["Email<br/><i>Formal notices</i>"]
    end

    subgraph L6["DATA SOURCES — Lakeflow Connect"]
        direction LR
        ORA["Oracle DB<br/><i>Loan Mgmt · CDC</i>"]
        ICE["SQL Server<br/><i>IceNet · CDC</i>"]
        ZEN["Zendesk<br/><i>Contacts · Stream</i>"]
        SFTP2["SFTP<br/><i>Collections</i>"]
        CS["ClearScore<br/><i>Open Banking</i>"]
    end

    APP --> LLM
    LLM --> PTP & BTC
    LLM --> C360 & PAY & OB
    LLM --> SC & VUL & RAG
    LLM -.->|"trace every decision"| MLF
    RAG -->|"submit for approval"| APQ
    APQ -->|"approved"| WA & SMS2 & EMAIL
    APQ -.->|"governed"| UC
    C360 -.-> UC
    ORA --> C360
    ICE --> C360
    ZEN --> PAY
    CS --> OB
    SFTP2 --> C360

