flowchart TB

    subgraph SRC["CURRENT DATA SOURCES"]
        direction LR
        ICE["IceNet<br/><i>SQL Server · 3x daily</i><br/><i>→ Oracle end 2026</i>"]
        O6K["O6K Events<br/><i>GCS/PubSub · hourly</i>"]
        ZEN["Zendesk<br/><i>Fivetran · hourly</i>"]
        MAIL["Mailchimp<br/><i>Fivetran · hourly</i>"]
        FTP["Collections FTP<br/><i>CSV/XML · daily</i>"]
        CS["ClearScore<br/><i>Open Banking API</i>"]
    end

    subgraph DBX["DATABRICKS PLATFORM (EXISTING)"]
        direction LR
        subgraph MED["Medallion Architecture"]
            direction LR
            BRZ["Bronze<br/><i>Raw</i>"]
            SLV["Silver<br/><i>Cleansed<br/>every 2-4 hrs</i>"]
            GLD["Gold<br/><i>Curated<br/>up to 3x daily</i>"]
        end
    end

    subgraph NEW["NEW: AI COLLECTIONS LAYER"]
        direction TB
        subgraph FT["Feature Tables (Unity Catalog)"]
            direction LR
            C360["Customer 360"]
            PAYH["Payment History"]
            OBD["Open Banking"]
        end
        subgraph AGENT["AI Agent — Claude Sonnet via FMAPI"]
            direction LR
            PTP["Propensity-to-Pay<br/><i>MLflow Model Serving</i>"]
            BTC["Best-Time-to-Contact<br/><i>MLflow Model Serving</i>"]
            SC["Scorecard<br/><i>MCP Server</i>"]
            VUL["Vulnerability<br/><i>FCA Engine</i>"]
            RAG["Comms<br/><i>RAG · Vector Search</i>"]
        end
        APQ["Approval Queue<br/><i>UC Delta Table</i>"]
    end

    subgraph OBS["OBSERVABILITY"]
        direction LR
        MLF["MLflow 3.0 Tracing<br/><i>Replaces Langfuse</i>"]
        UC["Unity Catalog<br/><i>Governance · Lineage</i>"]
    end

    subgraph CON["CURRENT CONSUMERS"]
        direction LR
        EXCEL["Ops Excel<br/><i>Live query</i>"]
        DEC["O6K Decision<br/>Engines<br/><i>Daily batch</i>"]
        PBI["Power BI<br/><i>Daily refresh</i>"]
        MCP["Claude / Cursor<br/><i>MCP (NEW)</i>"]
    end

    subgraph OUT["NEW: OUTPUT CHANNELS"]
        direction LR
        WA["WhatsApp<br/><i>Business API</i>"]
        SMS2["SMS"]
        EMAIL["Email"]
    end

    ICE & O6K & ZEN & MAIL & FTP -->|"batch"| BRZ
    BRZ --> SLV --> GLD
    CS -->|"API"| OBD
    GLD --> C360 & PAYH
    GLD --> EXCEL & DEC & PBI & MCP
    C360 & PAYH & OBD --> PTP & BTC & SC & VUL
    VUL & SC --> RAG
    RAG -->|"submit"| APQ
    APQ -->|"approved"| WA & SMS2 & EMAIL
    AGENT -.->|"trace"| MLF
    FT -.-> UC

