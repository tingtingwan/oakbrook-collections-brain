flowchart TB

    subgraph L1["USER INTERFACE — Databricks App"]
        APP["Collections Workbench<br/><i>FastAPI + SSE</i>"]
    end

    subgraph L2["LLM — Claude Sonnet 4.6 via FMAPI"]
        direction LR
        AGENT["Agent Chat<br/><i>Tool-calling orchestration</i>"]
        COMMS["Comms Generation<br/><i>Personalised WhatsApp/SMS</i>"]
        VULN["Vulnerability Assessment<br/><i>FCA Consumer Duty</i>"]
    end

    subgraph L3["ML MODELS — MLflow Model Serving"]
        direction LR
        PTP["oakbrook-ptp-model<br/><i>Propensity-to-Pay<br/>Serving Endpoint</i>"]
        BTC["oakbrook-btc-model<br/><i>Best-Time-to-Contact<br/>Serving Endpoint</i>"]
    end

    subgraph L4["DATA — UC Feature Tables"]
        direction LR
        C360["customer_360<br/><i>100 customers<br/>Feature Table + PK</i>"]
        PAY["payment_history<br/><i>~400 records</i>"]
        OB["open_banking_data<br/><i>~50 records</i>"]
    end

    subgraph L5["SCORECARD — UC SQL Function"]
        SC["collection_scorecard<br/><i>Oakbrook-defined rules<br/>6 segments · SQL logic<br/>MCP Server pattern</i>"]
    end

    subgraph L6["GOVERNANCE — Unity Catalog"]
        direction LR
        APQ["Approval Queue<br/><i>UC Delta Table<br/>Human-in-the-loop</i>"]
        MLF["MLflow 3.0<br/><i>Experiments · Registry<br/>Model Serving · Tracing</i>"]
        UC["Unity Catalog<br/><i>Governance · Lineage</i>"]
    end

    subgraph L7["OUTPUT CHANNELS"]
        direction LR
        WA["WhatsApp"]
        SMS2["SMS"]
        EMAIL["Email"]
    end

    subgraph L8["DATA SOURCES — Lakeflow Connect"]
        direction LR
        ICE["IceNet / Oracle<br/><i>CDC</i>"]
        ZEN["Zendesk<br/><i>Fivetran</i>"]
        CS["ClearScore<br/><i>Open Banking</i>"]
        FTP["SFTP / Mailchimp"]
    end

    APP --> AGENT
    AGENT --> PTP & BTC
    AGENT --> C360 & PAY & OB
    AGENT --> SC & VULN
    AGENT --> COMMS
    COMMS -->|"submit"| APQ
    APQ -->|"approved"| WA & SMS2 & EMAIL
    L3 -.->|"registered in"| MLF
    C360 -.-> UC
    SC -.->|"reads from"| C360
    APQ -.-> UC
    ICE & ZEN & FTP --> C360
    CS --> OB

